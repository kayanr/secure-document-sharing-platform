spring.application.name=secure-doc-backend

# Server
server.port=8080

# Database
# Replace with your MySQL host, port, and database name
spring.datasource.url=jdbc:mysql://localhost:3306/your_database_name
spring.datasource.username=your_mysql_username
# Set this as an environment variable — never hardcode the password here
# export DB_PASSWORD=your_password
spring.datasource.password=${DB_PASSWORD}

# JPA
# ddl-auto options: update (dev), validate (prod), create-drop (testing only)
spring.jpa.hibernate.ddl-auto=update
# Set to false in production to avoid exposing SQL in logs
spring.jpa.show-sql=true

# JWT (added in Phase 2)
# Set this as an environment variable — never hardcode the secret here
# export JWT_SECRET=your_jwt_secret
# jwt.secret=${JWT_SECRET}
# jwt.expiration=86400000
